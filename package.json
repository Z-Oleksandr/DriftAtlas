{
  "name": "driftatlas",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "preprocess:check": "test -f preprocessing/.venv/bin/python || (echo 'Run: cd preprocessing && python -m venv .venv && .venv/bin/pip install -r preprocessing/requirements.txt' && exit 1)",
    "preprocess": "npm run preprocess:check && preprocessing/.venv/bin/python preprocessing/build_days.py && preprocessing/.venv/bin/python preprocessing/build_timeseries.py",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@types/d3": "^7.4.3",
    "@types/three": "^0.184.0",
    "d3": "^7.9.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "zod": "^4.4.1"
  }
}
