# Absolute path to the drift-repo-analysis folder produced by the Driftool
# analysis package. Consumed only by the preprocessing script — not exposed
# to the browser, so no VITE_ prefix.
#
# Copy this file to .env and set the value to the path on your machine.
# Wrap the value in double quotes if it contains spaces.
DRIFT_REPO_ANALYSIS_PATH="/absolute/path/to/drift-repo-analysis"
